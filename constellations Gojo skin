.latest.news.module h3.heading,
.latest.messages.module.odd h3.heading,
.social.module h3.heading {
  border-bottom: 2px solid #DEB887;
}

.splash .favorite li:nth-of-type(2n+1) a,
.splash .favorite li:nth-of-type(2n+2) a {
  background: rgba(0, 0, 0, 0);
  color: #DEB887;
  border: 1px solid #ffe8b4;
  box-shadow: 0 0 8px #ffe8b4;
}

.splash .favorite li:nth-of-type(2n+1) a::before,
.splash .favorite li:nth-of-type(2n+2) a::before {
  content: "✨";
  text-shadow: 0 0 4px #ffe8b4;
}

.splash .favorite li:nth-of-type(2n+1) a:hover,
.splash .favorite li:nth-of-type(2n+2) a:hover {
  background: #DEB887;
  color: #000 !important;
}

.splash .favorite {
  position: relative;
  padding-bottom: 22px;
}

.splash .favorite::before {
  content: "";
  position: absolute;
  right: 0;
  top: 98%;
  transform: translateY(-50%);
  width: 80px;
  height: 80px;
  background-image: url("https://i.ibb.co/FbQNsrVs/png-preview-rev-1.png");
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}

.splash .favorite::after {
  content: "🪐";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  text-align: center;
  font-size: 20px;
  color: transparent !important;
  text-shadow: 0 0 1px #ffe8b4;
  opacity: 0.9;
  white-space: nowrap;
}

.news.index.group li.post.group {
  background: rgba(0, 0, 0, 0.5);
  border: 1px solid #ffe8b4;
  border-radius: 8px;
  padding: .5em;
